# Copy this file to .env and fill in your values.
# These are exposed to the client (React Native) — they are safe to include
# as the Supabase anon key is designed to be public. Row-Level Security (RLS)
# on the Supabase side is what keeps data private.

# Found in: Supabase Dashboard → Project → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Supabase Dashboard → Project → Settings → API → anon / public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
