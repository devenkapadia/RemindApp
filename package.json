{
  "name": "remind-app",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --watchAll=false"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "setupFiles": ["<rootDir>/src/__tests__/setup.js"],
    "testMatch": ["**/__tests__/**/*.test.{js,ts}"],
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native|expo|@expo)/)"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/src/__tests__/__mocks__/react-native.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__tests__/__mocks__/async-storage.js",
      "^expo-modules-core(/.*)?$": "<rootDir>/src/__tests__/__mocks__/expo-modules-core.js",
      "^expo-sqlite(/.*)?$": "<rootDir>/src/__tests__/__mocks__/expo-sqlite.js",
      "^expo-notifications(/.*)?$": "<rootDir>/src/__tests__/__mocks__/expo-notifications.js",
      "^expo-constants(/.*)?$": "<rootDir>/src/__tests__/__mocks__/expo-modules-core.js",
      "^expo-device(/.*)?$": "<rootDir>/src/__tests__/__mocks__/expo-modules-core.js",
      "^@expo/vector-icons(/.*)?$": "<rootDir>/src/__tests__/__mocks__/expo-vector-icons.js",
      "^@react-navigation/.*$": "<rootDir>/src/__tests__/__mocks__/react-navigation.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{js,ts}",
      "!src/**/__tests__/**"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-notifications": "~0.32.17",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~54.0.0",
    "jest": "^29.7.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
